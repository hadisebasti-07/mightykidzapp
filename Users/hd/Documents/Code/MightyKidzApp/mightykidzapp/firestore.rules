
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }
    
    function isWelcomeIC() {
        return hasRole('welcome_ic');
    }

    function isStaff() {
      return isAdmin() || isWelcomeIC();
    }
    
    function isExistingDoc() {
      return resource != null;
    }

    function isConsistentIdOnCreate(docId) {
      return request.resource.data.id == docId;
    }

    function isImmutableId() {
      return request.resource.data.id == resource.data.id;
    }

    function isConsistentParentLinkOnCreate(kidId) {
      return request.resource.data.kidId == kidId;
    }

    function isImmutableParentLink() {
      return request.resource.data.kidId == resource.data.kidId;
    }

    // -------------------------------------------------------------------------
    // Admin Role-Based Access Control
    // -------------------------------------------------------------------------
    match /admins/{adminUid} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if false; // Must be done via console or trusted backend
      allow update: if false;
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // Public & Pending Collections
    // -------------------------------------------------------------------------
    match /pending_kids/{kidId} {
      // Anyone can submit a registration.
      // This rule is intentionally broad on fields to allow for future form changes.
      // The key is that only an admin can read/promote this data.
      allow create: if request.resource.data.id == kidId
                    && request.resource.data.firstName is string
                    && request.resource.data.lastName is string
                    && request.resource.data.dateOfBirth is string
                    && request.resource.data.gender is string
                    && request.resource.data.parentName is string
                    && request.resource.data.parentPhone is string
                    && request.resource.data.status == 'pending'
                    && request.resource.data.submittedAt == request.time;
      // Only admins can manage pending registrations
      allow read, list, update, delete: if isAdmin();
    }
    
    // -------------------------------------------------------------------------
    // Core Data Collections
    // -------------------------------------------------------------------------
    match /{path=**}/activities/{activityId} {
      allow create: if isStaff();
      allow read: if isAdmin(); // Only admins see dashboard/trends
      allow update: if false;
      allow delete: if false;
    }

    match /kids/{kidId} {
      allow get: if isStaff();
      allow list: if isStaff();
      allow create: if isAdmin() && isConsistentIdOnCreate(kidId);
      allow update: if (isAdmin() && isExistingDoc() && isImmutableId()) ||
                     (isWelcomeIC() && isExistingDoc() && isImmutableId() &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coinsBalance', 'totalAttendance']));
      allow delete: if isAdmin() && isExistingDoc();

      match /attendances/{attendanceId} {
        allow get: if isStaff();
        allow list: if isStaff();
        allow create: if isStaff() && isConsistentIdOnCreate(attendanceId) && isConsistentParentLinkOnCreate(kidId);
        allow update: if isAdmin() && isExistingDoc() && isImmutableId() && isImmutableParentLink();
        allow delete: if isAdmin() && isExistingDoc();
      }

      match /coinTransactions/{transactionId} {
        allow get: if isStaff();
        allow list: if isStaff();
        allow create: if isStaff() && isConsistentIdOnCreate(transactionId) && isConsistentParentLinkOnCreate(kidId);
        allow update: if isAdmin() && isExistingDoc() && isImmutableId() && isImmutableParentLink();
        allow delete: if isAdmin() && isExistingDoc();
      }

      match /redemptions/{redemptionId} {
        allow get: if isStaff();
        allow list: if isStaff();
        allow create: if isStaff() && isConsistentIdOnCreate(redemptionId) && isConsistentParentLinkOnCreate(kidId);
        allow update: if isAdmin() && isExistingDoc() && isImmutableId() && isImmutableParentLink();
        allow delete: if isAdmin() && isExistingDoc();
      }
    }

    match /gifts/{giftId} {
      allow get: if isStaff();
      allow list: if isStaff();
      allow create: if isAdmin() && isConsistentIdOnCreate(giftId);
      allow update: if (isAdmin() && isExistingDoc() && isImmutableId()) ||
                     (isWelcomeIC() && isExistingDoc() && isImmutableId() &&
                      request.resource.data.stock == resource.data.stock - 1 && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']));
      allow delete: if isAdmin() && isExistingDoc();
    }

    match /volunteers/{volunteerId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin() && isConsistentIdOnCreate(volunteerId);
      allow update: if isAdmin() && isExistingDoc() && isImmutableId();
      allow delete: if isAdmin() && isExistingDoc();
    }

    match /volunteerSchedules/{scheduleId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin() && isConsistentIdOnCreate(scheduleId);
      allow update: if isAdmin() && isExistingDoc() && isImmutableId();
      allow delete: if isAdmin() && isExistingDoc();
    }
  }
}
